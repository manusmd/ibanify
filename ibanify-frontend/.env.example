# Leave empty to use the Vite dev proxy (/api -> http://localhost:8080).
# For production or custom backend URL:
# VITE_API_BASE_URL=http://localhost:8080

# Optional. If set (non-empty), the app shows a password screen first.
# Persisted unlock: SHA-256 of the password in localStorage (key ibanify.access.sha256).
# VITE_ACCESS_PASSWORD=your-secret
